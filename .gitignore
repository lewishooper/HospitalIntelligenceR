# =============================================================================
# HospitalIntelligenceR .gitignore
# =============================================================================


# -----------------------------------------------------------------------------
# Role outputs — extraction CSVs, downloaded PDFs, per-hospital files
# Regenerable from Phase 1/2 runs.
# -----------------------------------------------------------------------------
roles/*/outputs/
# -----------------------------------------------------------------------------
# Exception: LLM classification results are expensive to regenerate (11+ hr
# Ollama run) and are a tracked analytical asset, not raw scrape output.
# -----------------------------------------------------------------------------
!roles/minutes/outputs/llm_run1_results.csv
!roles/minutes/outputs/llm_run1_missing.csv
analysis/data/

# -----------------------------------------------------------------------------
# Logs — regenerable on every run, noisy in diffs, accumulate quickly
# -----------------------------------------------------------------------------
logs/
*.log


# -----------------------------------------------------------------------------
# Analysis outputs — figures and tables regenerate from scripts.
# DO NOT ignore analysis/data/ — curated analytical CSVs are tracked assets.
# -----------------------------------------------------------------------------
analysis/outputs/


# -----------------------------------------------------------------------------
# Dev/sandbox
# -----------------------------------------------------------------------------
dev/
docs/responsesTypora/


# -----------------------------------------------------------------------------
# R environment files
# -----------------------------------------------------------------------------
.Rhistory
.RData
.Rproj.user/


# -----------------------------------------------------------------------------
# Sensitive config
# -----------------------------------------------------------------------------
config_secrets.R
.env


# -----------------------------------------------------------------------------
# OS / editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db